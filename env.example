# Frontend environment variables
# Copy this file to .env for local development, or set these directly
# in the Vercel dashboard under Project Settings → Environment Variables
# for production.

# The base URL of your backend API, including the /api path.
# Local dev example:  http://localhost:5000/api
# Production example: https://your-app-name.up.railway.app/api
VITE_API_URL=http://localhost:5000/api
